# --- MongoDB ---
# Get this from MongoDB Atlas (or your own MongoDB server).
# Example: mongodb+srv://user:password@cluster0.xxxxx.mongodb.net/avm?retryWrites=true&w=majority
MONGODB_URI=mongodb://localhost:27017/avm

# --- Gmail (for Nodemailer) ---
# Use a Gmail App Password (NOT your real Gmail password).
# Create one at: https://myaccount.google.com/apppasswords
EMAIL_USER=yourgmail@gmail.com
EMAIL_APP_PASSWORD=your_app_password
# Legacy aliases (still supported): GMAIL_USER / GMAIL_APP_PASSWORD

# --- Server config ---
PORT=4000
JWT_SECRET=change-me-to-a-long-random-string
# Where the contact form messages are delivered. Defaults to GMAIL_USER.
CONTACT_TO=codexlydev@gmail.com

# --- CORS ---
# Comma-separated list of allowed origins. Use * during local dev only.
# In production set this to your deployed frontend URL(s), e.g.:
#   CORS_ORIGIN=https://your-app.surge.sh,https://your-custom-domain.com
CORS_ORIGIN=*
